# Backend runtime environment (production baseline; adjust for local development)
ENV=production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://your-frontend.example.com
API_KEY=replace-with-strong-secret
LLM_MODEL=deterministic-sim-v1
LLM_TIMEOUT_SECONDS=2.0
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_MS=150
MEMORY_BACKEND=sqlite
MEMORY_DB_URL=sqlite:///backend/app/data/memory.db
MEMORY_STORE_PATH=backend/app/data/memory.json
MAX_REQUEST_SIZE_BYTES=1048576
RATE_LIMIT_REQUESTS_PER_WINDOW=60
RATE_LIMIT_WINDOW_SECONDS=60
AUTONOMY_ENABLED=true
AUTONOMY_POLL_SECONDS=20
AUTONOMY_MAX_RUNS=50
LIGHTDASH_API_URL=
LIGHTDASH_API_KEY=
LIGHTDASH_PROJECT=autopilotops
AIRIA_API_URL=
AIRIA_API_KEY=
MODULATE_API_URL=
MODULATE_API_KEY=
MODULATE_VOICE=

# Frontend optional integrations
VITE_API_KEY=
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
